        "parameters": [
          {
            "name": "modelId",
            "required": true,
            "in": "path",
            "description": "UUID del modelo de casco",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sizeId",
            "required": true,
            "in": "path",
            "description": "UUID de la talla",
