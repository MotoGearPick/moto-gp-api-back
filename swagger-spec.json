  "info": {
    "title": "Moto Gear Picker API",
    "description": "API para selección y gestión de equipamiento de moto",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "CreateHelmetModelDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "brandId": {
            "type": "string"
          },
          "helmetType": {
            "type": "string",
            "enum": [
              "full_face",
              "modular",
              "open_face",
              "half",
              "off_road"
            ]
          },
          "safetyRating": {
            "type": "number",
            "minimum": 1
          },
          "shellMaterial": {
            "type": "string",
            "enum": [
              "polycarbonate",
              "fiberglass",
              "carbon_fiber"
            ]
          },
          "shellSizes": {
            "type": "number",
            "minimum": 1
          },
          "weightGrams": {
            "type": "number",
            "minimum": 0
          },
          "visorAntiScratch": {
            "type": "boolean"
          },
          "visorAntiFog": {
            "type": "boolean"
          },
          "visorPinlock": {
            "type": "string",
            "enum": [
              "pinlock_30",
              "pinlock_30_max_vision",
              "pinlock_70",
              "pinlock_70_max_vision",
              "pinlock_120",
              "pinlock_120_max_vision",
              "pinlock_evo",
              "pinlock_protectint",
              "included_unknown",
              "not_included",
              "not_compatible"
            ]
          },
          "sunVisor": {
            "type": "boolean"
          },
          "sunVisorType": {
            "type": "string"
          },
          "intercomReady": {
            "type": "boolean"
          },
          "intercomDesignedBrand": {
            "type": "string"
          },
          "intercomDesignedModel": {
            "type": "string"
          },
          "removableLining": {
            "type": "boolean"
          },
          "washableLining": {
            "type": "boolean"
          },
          "emergencyRelease": {
            "type": "boolean"
          },
          "closureType": {
            "type": "string",
            "enum": [
              "double_d_ring",
              "micrometric",
              "quick_release",
              "magnetic",
              "pinch_buckle"
            ]
          },
          "certification": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "dot",
                "snell",
                "ece_2206",
                "ece_2205",
                "fim"
              ]
            }
          }
        },
        "required": [
          "name",
          "slug",
          "brandId",
          "helmetType"
