          },
          {
            "name": "visorPinlock",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "pinlock_30",
                "pinlock_30_max_vision",
                "pinlock_70",
                "pinlock_70_max_vision",
                "pinlock_120",
                "pinlock_120_max_vision",
                "pinlock_evo",
                "pinlock_protectint",
                "included_unknown",
                "not_included",
                "not_compatible"
              ]
            }
          },
          {
            "name": "certification",
            "required": false,
            "in": "query",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "dot",
                  "snell",
                  "ece_2206",
                  "ece_2205",
                  "fim"
                ]
              }
            }
          },
          {
            "name": "colorFamily",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "black",
                "white",
                "red",
                "blue",
                "green",
                "yellow",
                "orange",
                "pink",
                "purple",
                "grey",
                "silver",
                "gold",
                "brown",
                "carbon",
                "multicolor",
                "bronze",
                "hi_vis"
              ]
            }
          },
          {
            "name": "sunVisor",
            "required": false,
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "intercomReady",
            "required": false,
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "minSafetyRating",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "maximum": 5,
              "type": "number"
            }
          },
          {
            "name": "maxWeightGrams",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 0,
              "type": "number"
            }
          },
          {
            "name": "minPrice",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 0,
              "type": "number"
            }
          },
          {
            "name": "maxPrice",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 0,
              "type": "number"
            }
          },
          {
            "name": "includeDeleted",
            "required": false,
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "page",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "default": 1,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "maximum": 100,
              "default": 20,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista paginada de cascos (vista admin)"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "[Admin] Listar cascos",
        "tags": [
          "Admin — Helmets"
        ]
      },
      "post": {
        "operationId": "HelmetModelsAdminController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateHelmetModelDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Casco creado correctamente"
          },
          "400": {
            "description": "Datos inválidos"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "[Admin] Crear modelo de casco",
        "tags": [
          "Admin — Helmets"
        ]
      }
    },
    "/api/admin/gear/helmets/{id}": {
      "get": {
        "description": "Incluye todos los campos internos y variantes eliminadas.",
        "operationId": "HelmetModelsAdminController_findOne",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "UUID del modelo de casco",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Detalle completo del casco (vista admin)"
          },
          "404": {
            "description": "Casco no encontrado"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "[Admin] Obtener casco por ID",
        "tags": [
          "Admin — Helmets"
        ]
      },
      "put": {
        "description": "Todos los campos son opcionales (actualización parcial).",
        "operationId": "HelmetModelsAdminController_update",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "UUID del modelo de casco",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateHelmetModelDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Casco actualizado"
          },
          "404": {
            "description": "Casco no encontrado"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "[Admin] Actualizar modelo de casco",
        "tags": [
          "Admin — Helmets"
        ]
      },
      "delete": {
        "description": "Marca el casco como eliminado sin borrarlo de la base de datos. Restaurable con /restore.",
        "operationId": "HelmetModelsAdminController_remove",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "UUID del modelo de casco",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Casco eliminado (soft delete)"
          },
          "404": {
            "description": "Casco no encontrado"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "[Admin] Eliminar casco (soft delete)",
        "tags": [
          "Admin — Helmets"
        ]
      }
    },
    "/api/admin/gear/helmets/{id}/restore": {
      "post": {
        "description": "Revierte el soft delete, el casco vuelve al estado activo.",
        "operationId": "HelmetModelsAdminController_restore",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "UUID del modelo de casco",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Casco restaurado"
          },
          "404": {
            "description": "Casco no encontrado"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "[Admin] Restaurar casco eliminado",
        "tags": [
          "Admin — Helmets"
        ]
      }
    },
