            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "CreateHelmetSizeDto": {
        "type": "object",
        "properties": {
          "sizeLabel": {
            "type": "string",
            "pattern": "/^(XXS|XS|S|M|L|XL|XXL|XXXL|[0-9]{2,3})$/"
          }
        },
        "required": [
          "sizeLabel"
        ]
      },
      "CreateHelmetInventoryDto": {
        "type": "object",
        "properties": {
          "sizeId": {
            "type": "string"
          },
          "storeId": {
            "type": "string"
          },
          "price": {
            "type": "number",
            "minimum": 0
          },
          "currency": {
            "type": "string",
            "default": "USD"
          },
          "inStock": {
            "type": "boolean"
          },
          "affiliateUrl": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": [
          "sizeId",
          "storeId",
          "price",
          "inStock",
          "affiliateUrl"
        ]
      },
      "UpdateHelmetInventoryDto": {
        "type": "object",
        "properties": {
          "sizeId": {
            "type": "string"
          },
          "storeId": {
            "type": "string"
          },
          "price": {
            "type": "number",
            "minimum": 0
          },
          "currency": {
            "type": "string",
            "default": "USD"
          },
          "inStock": {
            "type": "boolean"
          },
          "affiliateUrl": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "LoginAdminDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "admin@motogear.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "example": "supersecret123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RegisterAdminDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "John Doe"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "admin@motogear.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "example": "supersecret123"
